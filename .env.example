# GED-ISIPA / AEIP Enterprise Platform - Environment Configuration
# Copy this file to .env and fill in the values

# ===== DATABASE =====
# SQLite (default for development)
DATABASE_URL=file:./db/custom.db
# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://ged_user:CHANGE_ME@localhost:5432/ged_isipa?schema=public

# ===== AUTHENTICATION =====
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
NEXTAUTH_URL=http://localhost:3000
# For HTTPS deployment:
# NEXTAUTH_URL=https://your-domain.com

# ===== EMAIL / SMTP =====
# Development: use Ethereal Email (https://ethereal.email) — fake SMTP that catches mail
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address for all outgoing emails
SMTP_FROM=noreply@aeip.cd

# ===== OPTIONAL: File Storage (not yet implemented) =====
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=ged-documents

# ===== OPTIONAL: Redis Cache (not yet implemented) =====
# REDIS_URL=redis://localhost:6379

# ============ WEB PUSH (VAPID) ============
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your@email.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
