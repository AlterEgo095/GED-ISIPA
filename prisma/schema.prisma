generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ORGANIZATION TYPES ============
enum OrganizationType {
  UNIVERSITY
  HOSPITAL
  COMPANY
  GOVERNMENT
  SME
  INSTITUTION
  NGO
  LAW_FIRM
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

// ============ RBAC ROLES (14+ roles) ============
enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  MANAGER
  USER
  VIEWER
  DEAN
  PROFESSOR
  DOCTOR
  NURSE
  LAWYER
  PARALEGAL
  CFO
  HR_MANAGER
  CIVIL_SERVANT
}

// ============ ORGANIZATION ============
model Organization {
  id     String             @id @default(cuid())
  name   String
  slug   String             @unique
  code   String             @unique
  type   OrganizationType
  status OrganizationStatus @default(TRIAL)
  plan   SubscriptionPlan   @default(FREE)

  // Branding
  logo         String?
  primaryColor String  @default("#0d9488")
  accentColor  String?

  // Settings (JSON)
  settings String @default("{}")

  // Subscription
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  maxUsers           Int       @default(10)
  maxStorage         Int       @default(1073741824)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                User[]
  departments          Department[]
  documents            Document[]
  modules              OrganizationModule[]
  workflows            Workflow[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  campuses             Campus[]
  webhooks             Webhook[]
  usageRecords         UsageRecord[]
  pluginInstances      PluginInstance[]
  folders              Folder[]
  externalIntegrations ExternalIntegration[]
  documentComments     DocumentComment[]
  documentShares       DocumentShare[]
  documentTags         DocumentTag[]
}

// ============ USER ============
model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String
  role     Role   @default(VIEWER)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Department
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Status
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  lastLogin DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  documents         Document[]
  auditLogs         AuditLog[]
  accessLogs        AccessLog[]
  notifications     Notification[]
  resets            PasswordReset[]
  documentComments  DocumentComment[]
  pushSubscriptions PushSubscription[]
}

// ============ DEPARTMENT ============
model Department {
  id          String  @id @default(cuid())
  name        String
  code        String
  description String?
  isDeleted   Boolean @default(false)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users     User[]
  documents Document[]

  @@unique([organizationId, code])
}

// ============ DOCUMENT ============
enum DocumentType {
  ACADEMIC_RECORD
  ADMINISTRATIVE
  FINANCIAL
  CORRESPONDENCE
  REPORT
  CONTRACT
  CERTIFICATE
  MEMO
  POLICY
  MEDICAL_RECORD
  LEGAL_BRIEF
  INVOICE
  PROPOSAL
  OTHER
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  IN_REVIEW
  PENDING_APPROVAL
  PENDING_REVISION
  APPROVED
  PUBLISHED
  ARCHIVED
  REJECTED
  DESTROYED
  EXPIRED
  REVOKED
}

enum Classification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

model Document {
  id             String         @id @default(cuid())
  title          String
  reference      String         @unique
  description    String?
  type           DocumentType
  status         DocumentStatus @default(DRAFT)
  classification Classification @default(INTERNAL)

  // File info
  filePath String
  fileName String
  fileSize Int
  mimeType String
  fileHash String

  // Versioning
  version  Int     @default(1)
  tags     String  @default("")
  metadata String?

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Relations
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  // Folder
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  // Workflow & Review
  workflowStateId String?
  workflowState   WorkflowState? @relation(fields: [workflowStateId], references: [id])
  reviewComment   String?
  reviewedAt      DateTime?
  reviewedById    String?
  publishedAt     DateTime?
  publishedById   String?

  // Archive
  isArchived      Boolean   @default(false)
  archivedAt      DateTime?
  archivedBy      String?
  archiveRef      String?
  retentionPeriod Int?
  expiresAt       DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  // Destruction approval (separation of duties)
  destructionApproved   Boolean   @default(false)
  destructionApprovedBy String?
  destroyAt             DateTime?
  destroyedBy          String?
  retentionPolicy     String?
  previousStatus      String?
  viewCount           Int            @default(0)
  downloadCount       Int            @default(0)
  rejectedBy          String?
  rejectionReason     String?
  rejectedAt          DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  versions               DocumentVersion[]
  auditLogs              AuditLog[]
  accessLogs             AccessLog[]
  documentComments       DocumentComment[]
  documentMetadata       DocumentMetadata[]
  documentShares         DocumentShare[]
  documentTagAssignments DocumentTagAssignment[]
}

// ============ DOCUMENT VERSION ============
model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  version     Int
  filePath    String
  fileName    String
  fileSize    Int
  fileHash    String
  mimeType    String   @default("application/octet-stream")
  previousVersionId String?
  changeType  String   @default("UPDATE")
  changeLog   String?
  createdBy   String
  createdAt   DateTime @default(now())
}

// ============ FOLDER ============
model Folder {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6b7280")
  icon        String?
  order       Int      @default(0)
  createdBy   String?
  parentId    String?
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    Folder[] @relation("FolderHierarchy")

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@unique([organizationId, name, parentId])
}

// ============ DOCUMENT COMMENT ============
model DocumentComment {
  id         String            @id @default(cuid())
  documentId String
  document   Document          @relation(fields: [documentId], references: [id])
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  content    String
  parentId   String?
  parent     DocumentComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    DocumentComment[] @relation("CommentReplies")
  mentions    String           @default("[]")
  isResolved Boolean           @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ============ DOCUMENT METADATA ============
model DocumentMetadata {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  key         String
  value       String
  type        String   @default("TEXT")
  required    Boolean  @default(false)
  category    String?
  options     String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([documentId, key])
}

// ============ DOCUMENT SHARE ============
model DocumentShare {
  id            String    @id @default(cuid())
  documentId    String
  document      Document  @relation(fields: [documentId], references: [id])
  sharedWith    String
  sharedBy      String
  permission    String    @default("READ")
  shareType     String    @default("USER")
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  downloadLimit Int?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([documentId, sharedWith])
}

// ============ DOCUMENT TAG ============
model DocumentTag {
  id             String       @id @default(cuid())
  name           String
  color          String       @default("#6b7280")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  assignments DocumentTagAssignment[]

  @@unique([organizationId, name])
}

// ============ DOCUMENT TAG ASSIGNMENT ============
model DocumentTagAssignment {
  id         String      @id @default(cuid())
  documentId String
  document   Document    @relation(fields: [documentId], references: [id])
  tagId      String
  tag        DocumentTag @relation(fields: [tagId], references: [id])
  assignedBy String
  createdAt  DateTime    @default(now())

  @@unique([documentId, tagId])
}

// ============ WORKFLOW ENGINE ============
model Workflow {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Config
  initialStateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  states      WorkflowState[]
  transitions WorkflowTransition[]
}

model WorkflowState {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id])
  name       String
  isInitial  Boolean  @default(false)
  isFinal    Boolean  @default(false)
  color      String   @default("#6b7280")
  order      Int      @default(0)

  // Relations
  documents       Document[]
  fromTransitions WorkflowTransition[] @relation("FromTransitions")
  toTransitions   WorkflowTransition[] @relation("ToTransitions")
}

model WorkflowTransition {
  id           String        @id @default(cuid())
  workflowId   String
  workflow     Workflow      @relation(fields: [workflowId], references: [id])
  fromStateId  String
  fromState    WorkflowState @relation("FromTransitions", fields: [fromStateId], references: [id])
  toStateId    String
  toState      WorkflowState @relation("ToTransitions", fields: [toStateId], references: [id])
  name         String
  allowedRoles String        @default("[]")
  condition    String?
}

// ============ MODULE ENGINE ============
enum ModuleStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  moduleKey      String
  name           String
  description    String?
  status         ModuleStatus @default(INACTIVE)
  config         String       @default("{}")
  activatedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, moduleKey])
}

// ============ SUBSCRIPTION/BILLING ============
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String
  organization       Organization       @relation(fields: [organizationId], references: [id])
  plan               SubscriptionPlan
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  amount             Float              @default(0)
  currency           String             @default("USD")
  stripeSessionId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ AUDIT LOG ============
enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  RESTORE_DELETED
  DOWNLOAD
  SHARE
  SHARE_CREATE
  SHARE_ACCESS
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  MODULE_ACTIVATE
  MODULE_SUSPEND
  WORKFLOW_EXECUTE
  ORGANIZATION_CREATE
  ORGANIZATION_SUSPEND
  API_KEY_CREATE
  API_KEY_REVOKE
  WEBHOOK_FIRE
  PLUGIN_INSTALL
  PLUGIN_UNINSTALL
  CAMPUS_CREATE
  SUBSCRIPTION_CHANGE
  COMMENT_ADD
  COMMENT_RESOLVE
  DESTROY
  PERMANENT_DELETE
  PREVIEW
  REQUEST_REVISION
  METADATA_UPDATE
  TAG_ASSIGN
  VERSION_UPLOAD
  FOLDER_CREATE
  FOLDER_MOVE
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String
  details    String

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])

  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ============ ACCESS LOG ============
model AccessLog {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// ============ NOTIFICATION ============
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ============ PASSWORD RESET ============
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

// ============ SYSTEM SETTINGS ============
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  isSecret  Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt
}

// ================================================================
// MISSION 6.0 — INDUSTRIALISATION SAAS
// ================================================================

// ============ API KEYS (Public API Access) ============
enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  keyPrefix      String // First 8 chars for identification
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Permissions scope
  scopes     String @default("[\"read\"]")
  rateLimit  Int    @default(100) // requests per minute
  allowedIps String @default("[]") // JSON array of IP CIDRs, empty = all

  // Status
  status       ApiKeyStatus @default(ACTIVE)
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  requestCount Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  usageRecords UsageRecord[]
}

// ============ USAGE TRACKING (SaaS Quotas) ============
enum UsageType {
  API_CALL
  DOCUMENT_UPLOAD
  AI_OCR
  AI_EMBEDDING
  AI_CHAT
  AI_CLASSIFICATION
  STORAGE
  USER_SEAT
}

model UsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  usageType UsageType
  quantity  Int       @default(1)
  metadata  String    @default("{}") // JSON

  periodStart DateTime // Start of billing period
  periodEnd   DateTime // End of billing period

  createdAt DateTime @default(now())
}

// ============ PLAN FEATURES (SaaS Subscription Features) ============
model PlanFeature {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  featureKey  String // e.g., "ai_ocr", "api_access", "max_api_keys"
  featureName String
  featureType String           @default("boolean") // boolean, number, string
  value       String           @default("true")
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plan, featureKey])
}

// ============ PLUGINS (Extensible Architecture) ============
enum PluginStatus {
  PUBLISHED
  DRAFT
  DEPRECATED
  UNDER_REVIEW
}

model Plugin {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  version     String  @default("1.0.0")
  author      String?
  homepage    String?

  // Plugin metadata
  icon        String?
  category    String  @default("utility") // utility, integration, ai, workflow
  tags        String  @default("[]")
  permissions String  @default("[]") // JSON: required permissions

  // Plugin code/config
  config         String  @default("{}") // JSON: plugin configuration schema
  entryPoint     String? // URL or path to plugin entry
  settingsSchema String? // JSON schema for plugin settings

  // Status & distribution
  status    PluginStatus @default(DRAFT)
  downloads Int          @default(0)
  rating    Float        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  instances PluginInstance[]
}

model PluginInstance {
  id       String @id @default(cuid())
  pluginId String
  plugin   Plugin @relation(fields: [pluginId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Instance config
  settings    String   @default("{}")
  isActive    Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId, pluginId])
}

// ============ MULTI-CAMPUS ============
model Campus {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name     String
  code     String
  address  String?
  city     String?
  country  String?
  timezone String  @default("Africa/Casablanca")

  // Campus-specific settings
  logo         String?
  primaryColor String?
  settings     String  @default("{}")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
}

// ============ WEBHOOKS (External Integrations) ============
enum WebhookEvent {
  DOCUMENT_CREATED
  DOCUMENT_UPDATED
  DOCUMENT_APPROVED
  DOCUMENT_ARCHIVED
  WORKFLOW_COMPLETED
  USER_CREATED
  USER_DEACTIVATED
  SUBSCRIPTION_CHANGED
  AI_PROCESS_COMPLETED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

model Webhook {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name    String
  url     String
  secret  String // HMAC secret for payload signing
  events  String @default("[]") // JSON array of WebhookEvent
  headers String @default("{}") // JSON: custom HTTP headers

  status          WebhookStatus @default(ACTIVE)
  lastTriggeredAt DateTime?
  failureCount    Int           @default(0)
  successCount    Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id        String  @id @default(cuid())
  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id])

  event          String
  payload        String // JSON payload sent
  responseCode   Int?
  responseBody   String?
  responseTimeMs Int?
  isSuccess      Boolean @default(false)
  error          String?

  attemptedAt DateTime @default(now())
}

// ============ PUSH SUBSCRIPTIONS (PWA / Mobile) ============
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  endpoint  String  @unique
  p256dh    String // Public key
  auth      String // Auth secret
  userAgent String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ EXTERNAL INTEGRATION CONFIG ============
enum IntegrationType {
  SLACK
  EMAIL_SMTP
  S3_STORAGE
  GOOGLE_DRIVE
  ONEDRIVE
  WEBDAV
  LDAP
  SAML_SSO
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

model ExternalIntegration {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  type         IntegrationType
  name         String
  config       String            @default("{}") // JSON: encrypted connection config
  status       IntegrationStatus @default(PENDING)
  lastSyncAt   DateTime?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, type])
}
